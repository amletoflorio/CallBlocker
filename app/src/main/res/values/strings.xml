    <!-- Changelog entries — v1.6.0 -->
    <string name="changelog_1_6_0_1">Advanced rule: allow a blocked number after X attempts in Y minutes</string>
    <string name="changelog_1_6_0_2">Temporary whitelist: numbers auto-whitelisted by the retry rule expire after the window</string>
    <string name="changelog_1_6_0_3">Boot receiver: option to auto-prompt for call screening role after reboot</string>
    <string name="changelog_1_6_0_4">Fixed: outgoing calls no longer appear in the blocked log</string>
    <string name="changelog_1_6_0_5">Fixed: outgoing calls no longer trigger a blocked notification</string>
    <string name="changelog_1_6_0_6">Settings split into Calls / Boot tabs for clearer organisation</string>

    <!-- Changelog entries — v1.5.0 -->
    <string name="changelog_1_5_0_1">Blocked call log: tappable entries with full detail screen (country, operator, type, history)</string>
    <string name="changelog_1_5_0_2">Call detail: Add to whitelist button and Search online shortcut</string>
    <string name="changelog_1_5_0_3">SIM slot recorded for each blocked call and shown in log and detail</string>
    <string name="changelog_1_5_0_4">Auto-clean log: configurable retention (7 / 30 / 90 days or never)</string>
    <string name="changelog_1_5_0_5">Home: suspension banner shows the date/time the protection resumes</string>
    <string name="changelog_1_5_0_6">Home toggle updates instantly when protection is suspended from Settings</string>
    <string name="changelog_1_5_0_7">Settings: last active tab is remembered across sessions</string>
    <string name="changelog_1_5_0_8">Improved layout responsiveness for large system font sizes and landscape mode</string>

    <!-- Changelog entries — v1.4.0 -->
    <string name="changelog_1_4_0_1">Dual SIM support: choose which SIM card(s) to protect</string>
    <string name="changelog_1_4_0_2">Language selector: system default, English, Italian</string>
    <string name="changelog_1_4_0_3">What\'s new screen with full version history</string>
    <string name="changelog_1_4_0_4">Dedicated Updates tab with auto-check and notifications</string>

    <!-- Changelog entries — v1.3.0 -->
    <string name="changelog_1_3_0_1">Automatic backup with configurable interval (daily / weekly / monthly)</string>
    <string name="changelog_1_3_0_2">Backups saved to Documents/CallBlocker/ with timestamp filename</string>
    <string name="changelog_1_3_0_3">Update checker via GitHub Releases API with opt-in toggle</string>
    <string name="changelog_1_3_0_4">Update dialog with release notes and download link</string>
    <string name="changelog_1_3_0_5">Version now read from BuildConfig instead of static string</string>

    <!-- Changelog entries — v1.2.0 -->
    <string name="changelog_1_2_0_1">Italian locale support (auto-detected from system)</string>
    <string name="changelog_1_2_0_2">Improved phone number formatting for IT, DE, FR, ES, UK, US</string>
    <string name="changelog_1_2_0_3">Whitelist contacts can now be edited</string>
    <string name="changelog_1_2_0_4">All UI strings extracted to strings.xml</string>

    <!-- Changelog entries — v1.1.0 -->
    <string name="changelog_1_1_0_1">Fixed toggle state not updating correctly on resume</string>
    <string name="changelog_1_1_0_2">Fixed toggle: now suspends/resumes protection instead of revoking role</string>
    <string name="changelog_1_1_0_3">Settings screen refactored with tab layout (Protection / Backup / Info)</string>
    <string name="changelog_1_1_0_4">In-app snackbar feedback for export/import operations</string>
    <string name="changelog_1_1_0_5">GitHub link added in Info tab</string>

