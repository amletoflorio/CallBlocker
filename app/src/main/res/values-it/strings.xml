    <!-- Changelog entries — v1.6.0 -->
    <string name="changelog_1_6_0_1">Regola avanzata: lascia passare un numero bloccato dopo X tentativi in Y minuti</string>
    <string name="changelog_1_6_0_2">Whitelist temporanea: i numeri aggiunti automaticamente dalla regola scadono alla fine della finestra</string>
    <string name="changelog_1_6_0_3">Boot receiver: opzione per riaprire automaticamente il dialog di screening al riavvio</string>
    <string name="changelog_1_6_0_4">Corretto: le chiamate effettuate non appaiono più nel log dei bloccati</string>
    <string name="changelog_1_6_0_5">Corretto: le chiamate effettuate non generano più notifiche di blocco</string>
    <string name="changelog_1_6_0_6">Impostazioni riorganizzate nei tab Chiamate / Avvio per maggiore chiarezza</string>

    <!-- Changelog entries — v1.5.0 -->
    <string name="changelog_1_5_0_1">Log chiamate bloccate: voci cliccabili con schermata dettaglio (paese, operatore, tipo, cronologia)</string>
    <string name="changelog_1_5_0_2">Dettaglio chiamata: pulsante Aggiungi alla whitelist e scorciatoia Cerca online</string>
    <string name="changelog_1_5_0_3">SIM registrata per ogni chiamata bloccata e mostrata nel log e nel dettaglio</string>
    <string name="changelog_1_5_0_4">Pulizia automatica log: retention configurabile (7 / 30 / 90 giorni o mai)</string>
    <string name="changelog_1_5_0_5">Home: il banner di sospensione mostra la data/ora in cui riprende la protezione</string>
    <string name="changelog_1_5_0_6">Il toggle Home si aggiorna immediatamente quando la protezione viene sospesa dalle Impostazioni</string>
    <string name="changelog_1_5_0_7">Impostazioni: l\'ultimo tab attivo viene ricordato tra le sessioni</string>
    <string name="changelog_1_5_0_8">Migliorata la reattività del layout per dimensioni font grandi e modalità landscape</string>

    <!-- Changelog entries — v1.4.0 -->
    <string name="changelog_1_4_0_1">Supporto Dual SIM: scegli quale SIM proteggere</string>
    <string name="changelog_1_4_0_2">Selettore lingua: predefinita di sistema, Inglese, Italiano</string>
    <string name="changelog_1_4_0_3">Schermata Novità con cronologia completa delle versioni</string>
    <string name="changelog_1_4_0_4">Tab Aggiornamenti dedicato con controllo automatico e notifiche</string>

    <!-- Changelog entries — v1.3.0 -->
    <string name="changelog_1_3_0_1">Backup automatico con intervallo configurabile (giornaliero / settimanale / mensile)</string>
    <string name="changelog_1_3_0_2">Backup salvati in Documenti/CallBlocker/ con nome file timestamp</string>
    <string name="changelog_1_3_0_3">Controllo aggiornamenti via GitHub Releases API con toggle opt-in</string>
    <string name="changelog_1_3_0_4">Dialog aggiornamento con note di rilascio e link di download</string>
    <string name="changelog_1_3_0_5">Versione ora letta da BuildConfig invece di stringa statica</string>

    <!-- Changelog entries — v1.2.0 -->
    <string name="changelog_1_2_0_1">Supporto localizzazione italiana (rilevamento automatico)</string>
    <string name="changelog_1_2_0_2">Formattazione numeri migliorata per IT, DE, FR, ES, UK, US</string>
    <string name="changelog_1_2_0_3">I contatti della whitelist possono ora essere modificati</string>
    <string name="changelog_1_2_0_4">Tutte le stringhe UI estratte in strings.xml</string>

    <!-- Changelog entries — v1.1.0 -->
    <string name="changelog_1_1_0_1">Corretto: stato toggle non si aggiornava correttamente alla ripresa</string>
    <string name="changelog_1_1_0_2">Corretto: toggle sospende/riprende la protezione invece di revocare il ruolo</string>
